# SPA configuration — fill these in from `aws cloudformation describe-stacks
# --stack-name discharge-audit --query 'Stacks[0].Outputs'` after deploy.
# Save the working copy as `.env.local` (gitignored).

# UserPoolId from the stack outputs
VITE_USER_POOL_ID=eu-west-2_XXXXXXXXX

# UserPoolClientId from the stack outputs (this is also the JWT 'aud' the
# API Gateway authoriser checks — the App Client id, NOT the User Pool id).
VITE_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# HttpApiEndpoint from the stack outputs (no trailing slash). The SPA POSTs
# to `${API_BASE}/generate` and polls `${API_BASE}/generations/{id}`.
VITE_API_BASE=https://XXXXXXXXXX.execute-api.eu-west-2.amazonaws.com

# Region pinned to eu-west-2 (ADR-003 rule 1: UK-only inference).
VITE_AWS_REGION=eu-west-2
